// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  EDITOR
  CONTRIBUTOR
}


datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now()) @map(name: "created_at")
  updatedAt         DateTime @default(now()) @map(name: "updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map(name: "accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map(name: "sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(CONTRIBUTOR)
  password      String?
  createdAt     DateTime  @default(now()) @map(name: "created_at")
  updatedAt     DateTime  @default(now()) @map(name: "updated_at")

  accounts      Account[]
  sessions      Session[]
  Post          Post[]
  refreshTokens RefreshToken[]
  notifications Notification[]

  stripeCustomerId       String?   @unique @map(name: "stripe_customer_id")
  stripeSubscriptionId   String?   @unique @map(name: "stripe_subscription_id")
  stripePriceId          String?   @map(name: "stripe_price_id")
  stripeCurrentPeriodEnd DateTime? @map(name: "stripe_current_period_end")

  @@map(name: "users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map(name: "verification_tokens")
}

model Post {
  id             String         @id @default(cuid())
  title          String
  content        Json?
  published      Boolean        @default(false)
  featured       Boolean        @default(false)
  createdAt      DateTime       @default(now()) @map(name: "created_at")
  updatedAt      DateTime       @default(now()) @map(name: "updated_at")
  authorId       String
  image          Json?
  likes          Int            @default(0)
  price          Float?
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  seoImage       String?
  template       String         @default("standard")
  banner         Json?
  relatedPostIds Json?
  scheduledAt    DateTime?
  bookable       Boolean   @default(false)
  avgRating      Float?
  ratingCount    Int            @default(0)
  author         User           @relation(fields: [authorId], references: [id])
  categories     PostCategory[]
  tags           PostTag[]
  comments       Comment[]

  @@index([authorId])
  @@index([published, updatedAt])
  @@index([published, scheduledAt])
  @@index([featured])
  @@map(name: "posts")
}

model Comment {
  id          String   @id @default(cuid())
  content     String
  authorName  String
  authorEmail String?
  postId      String
  approved    Boolean  @default(false)
  rating      Int?
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map(name: "created_at")

  @@index([postId, approved])
  @@map(name: "comments")
}

model Category {
  id             String         @id @default(cuid())
  name           String         @unique
  slug           String         @unique
  published      Boolean        @default(true)
  image          Json?
  order          Int            @default(0)
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  seoImage       String?
  template       String         @default("standard")
  banner         Json?
  createdAt DateTime       @default(now()) @map(name: "created_at")
  updatedAt DateTime       @default(now()) @map(name: "updated_at")
  posts     PostCategory[]
  menuItems MenuItem[]

  @@index([published])
  @@map(name: "categories")
}

model MenuItem {
  id         String    @id @default(cuid())
  title      String
  href       String
  type       String    @default("custom")
  order      Int       @default(0)
  disabled   Boolean   @default(false)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map(name: "menu_items")
}


model SiteConfig {
  id        String   @id @default("default")
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  @@map(name: "site_config")
}

model SiteDoc {
  key       String   @id
  title     String
  content   String   @db.Text
  updatedAt DateTime @updatedAt @map(name: "updated_at")

  @@map(name: "site_docs")
}

model Page {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  content        Json?
  published      Boolean  @default(false)
  image          Json?
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  seoImage       String?
  banner         Json?
  createdAt      DateTime @default(now()) @map(name: "created_at")
  updatedAt      DateTime @updatedAt       @map(name: "updated_at")

  @@map(name: "pages")
}

model EmailToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  type      String    // "RESET_PASSWORD"
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@map(name: "email_tokens")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now()) @map(name: "created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map(name: "refresh_tokens")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map(name: "created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map(name: "notifications")
}

model Booking {
  id           String   @id @default(cuid())
  name         String
  phone        String
  address      String?
  items        Json
  deliveryDate DateTime
  note         String?
  status       String   @default("pending")
  createdAt    DateTime @default(now()) @map(name: "created_at")
  updatedAt    DateTime @updatedAt       @map(name: "updated_at")

  @@index([status])
  @@index([deliveryDate])
  @@map(name: "bookings")
}

model PostCategory {
  postId     String
  categoryId String
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
  @@index([categoryId])
  @@map(name: "post_categories")
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now()) @map(name: "created_at")
  posts     PostTag[]

  @@map(name: "tags")
}

model PostTag {
  postId String
  tagId  String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
  @@map(name: "post_tags")
}

model SearchQuery {
  id        String   @id @default(cuid())
  query     String
  createdAt DateTime @default(now()) @map(name: "created_at")

  @@index([createdAt])
  @@map(name: "search_queries")
}

model DishGroup {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  dishes    Dish[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map(name: "dish_groups")
}

model Dish {
  id          String    @id @default(cuid())
  name        String
  description String?
  price       Float
  unit        String    @default("phần")
  image       String?
  available   Boolean   @default(true)
  order       Int       @default(0)
  groupId     String
  group       DishGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([groupId])
  @@map(name: "dishes")
}
